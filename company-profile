<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MYCASA Construction Services — Company Profile 2026</title>
    <style>
        @page {
            size: A4;
            margin: 0;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            line-height: 1.6;
            color: #2c3e50;
            background: #f4f6f8;
        }

        .page {
            width: 210mm;
            min-height: 297mm;
            margin: 20px auto;
            background: white;
            box-shadow: 0 0 20px rgba(0, 0, 0, 0.1);
            padding: 0;
            position: relative;
            overflow: hidden;
        }

        .header {
            background: linear-gradient(135deg, #1a252f 0%, #2c3e50 100%);
            color: white;
            padding: 60px 50px 50px;
            position: relative;
        }

        .header::after {
            content: '';
            position: absolute;
            bottom: -40px;
            left: 0;
            width: 100%;
            height: 80px;
            background: white;
            clip-path: ellipse(60% 100% at 50% 100%);
        }

        .header h1 {
            font-size: 2.8em;
            font-weight: 300;
            letter-spacing: 2px;
            margin-bottom: 10px;
        }

        .header .subtitle {
            font-size: 1.1em;
            opacity: 0.9;
            font-weight: 300;
            letter-spacing: 1px;
        }

        .header .year-badge {
            display: inline-block;
            background: rgba(255, 255, 255, 0.15);
            padding: 8px 20px;
            border-radius: 20px;
            margin-top: 20px;
            font-size: 0.9em;
            letter-spacing: 2px;
        }

        .content {
            padding: 60px 50px 40px;
        }

        .section {
            margin-bottom: 35px;
        }

        .section-title {
            color: #2c3e50;
            font-size: 1.4em;
            font-weight: 600;
            margin-bottom: 15px;
            padding-bottom: 8px;
            border-bottom: 3px solid #e67e22;
            display: inline-block;
        }

        .section-subtitle {
            color: #7f8c8d;
            font-size: 0.95em;
            font-style: italic;
            margin-bottom: 15px;
        }

        p {
            margin-bottom: 12px;
            text-align: justify;
        }

        .highlight-box {
            background: #f8f9fa;
            border-left: 4px solid #e67e22;
            padding: 20px 25px;
            margin: 20px 0;
            border-radius: 0 8px 8px 0;
        }

        .values-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
            margin-top: 15px;
        }

        .value-card {
            background: #f8f9fa;
            padding: 15px 20px;
            border-radius: 8px;
            border-top: 3px solid #e67e22;
        }

        .value-card strong {
            color: #2c3e50;
            display: block;
            margin-bottom: 5px;
            font-size: 1.05em;
        }

        .value-card span {
            color: #555;
            font-size: 0.9em;
        }

        .services-list {
            list-style: none;
            padding: 0;
        }

        .services-list li {
            padding: 12px 0 12px 30px;
            position: relative;
            border-bottom: 1px solid #eee;
        }

        .services-list li::before {
            content: '▸';
            position: absolute;
            left: 0;
            color: #e67e22;
            font-weight: bold;
        }

        .services-list li strong {
            color: #2c3e50;
            display: block;
            margin-bottom: 3px;
        }

        .services-list li span {
            color: #666;
            font-size: 0.9em;
        }

        .experience-box {
            background: linear-gradient(135deg, #f8f9fa 0%, #ffffff 100%);
            border: 1px solid #e0e0e0;
            border-radius: 10px;
            padding: 25px;
            margin: 20px 0;
        }

        .experience-box ul {
            list-style: none;
            padding-left: 0;
        }

        .experience-box li {
            padding: 8px 0 8px 25px;
            position: relative;
        }

        .experience-box li::before {
            content: '✓';
            position: absolute;
            left: 0;
            color: #27ae60;
            font-weight: bold;
        }

        .contact-section {
            background: #1a252f;
            color: white;
            padding: 40px 50px;
            margin-top: 40px;
        }

        .contact-section .section-title {
            color: white;
            border-bottom-color: #e67e22;
        }

        .contact-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-top: 20px;
        }

        .contact-item {
            margin-bottom: 12px;
        }

        .contact-item strong {
            color: #e67e22;
            display: block;
            font-size: 0.85em;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 3px;
        }

        .contact-item span {
            font-size: 0.95em;
            opacity: 0.9;
        }

        .footer-note {
            text-align: center;
            padding: 20px;
            color: #95a5a6;
            font-size: 0.85em;
            border-top: 1px solid #eee;
        }

        @media print {
            body {
                background: white;
            }

            .page {
                margin: 0;
                box-shadow: none;
            }
        }
    </style>
    <base target="_blank">
</head>

<body>
    <div class="page">
        <!-- Header -->
        <div class="header">
            <h1>MYCASA</h1>
            <div class="subtitle">Construction Services</div>
